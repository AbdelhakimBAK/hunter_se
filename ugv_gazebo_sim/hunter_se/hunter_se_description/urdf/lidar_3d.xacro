<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:macro name="lidar_3d" params="parent:=base_link">

        <!-- Support mast mounting the lidar to the chassis -->
        <link name="lidar_mast_link">
            <inertial>
                <mass value="0.2"/>
                <origin xyz="0 0 0.1075" rpy="0 0 0"/>
                <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-4"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0.1075" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="0.025" length="0.215"/>
                </geometry>
                <material name="mast_material">
                    <color rgba="0 0 0 1"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0.1075" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="0.025" length="0.215"/>
                </geometry>
            </collision>
        </link>

        <joint name="lidar_mast_joint" type="fixed">
            <parent link="${parent}"/>
            <child link="lidar_mast_link"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </joint>

        <link name="velodyne_link">
            <inertial>
                <mass value="0.01"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="0.05" length="0.07"/>
                </geometry>
                <material name="lidar_material">
                    <color rgba="0.3 0.3 0.3 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz=" 0 0 0" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="0.05" length="0.07"/>
                </geometry>
            </collision>
        </link>

        <joint name="velodyne_joint" type="fixed">
            <parent link="lidar_mast_link"/>
            <child link="velodyne_link"/>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
        </joint>

        <gazebo reference="lidar_mast_link">
            <visual>
                <material>
                    <ambient>0 0 0 1</ambient>
                    <diffuse>0 0 0 1</diffuse>
                    <specular>0.05 0.05 0.05 1</specular>
                </material>
            </visual>
        </gazebo>

        <gazebo reference="velodyne_link">
            <visual>
                <material>
                    <ambient>0.3 0.3 0.3 1</ambient>
                    <diffuse>0.3 0.3 0.3 1</diffuse>
                    <specular>0.1 0.1 0.1 1</specular>
                </material>
            </visual>
            <sensor name="velodyne" type="gpu_lidar">
                <gz_frame_id>velodyne_link</gz_frame_id>
                <topic>hunter_se/points</topic>
                <update_rate>10</update_rate>
                <lidar>
                    <scan>
                        <horizontal>
                            <!-- <samples>360</samples> --> <!-- default: 360 x 16 = 5,760 pts -->
                            <samples>1250</samples> <!-- denser: 1250 x 16 = 20,000 pts (closer to real Livox) -->

                            <resolution>1</resolution>
                            <min_angle>-3.14159</min_angle>
                            <max_angle>3.14159</max_angle>
                        </horizontal>
                        <vertical>
                            <samples>16</samples>
                            <resolution>1</resolution>
                            <min_angle>-0.261799</min_angle>
                            <max_angle>0.261799</max_angle>
                        </vertical>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>30</max>
                        <resolution>0.01</resolution>
                    </range>
                </lidar>
                <always_on>1</always_on>
                <visualize>false</visualize>
            </sensor>
        </gazebo>
    </xacro:macro>
</robot>
